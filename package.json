{
  "name": "light-bridge",
  "version": "0.1.0",
  "description": "Headless CLI refactoring engine for AI agents",
  "bin": {
    "light-bridge": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "smoke-test": "bash scripts/smoke-test.sh",
    "coverage": "vitest run --coverage",
    "check": "biome check . && pnpm build && pnpm test",
    "prepare": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@volar/typescript": "2.4.28",
    "@vue/language-core": "3.2.4",
    "chokidar": "5.0.0",
    "commander": "12.1.0",
    "ts-morph": "23.0.0",
    "typescript": "5.9.3",
    "zod": "3.25.76"
  },
  "pnpm": {
    "overrides": {
      "@volar/language-core": "2.4.28"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.3",
    "@types/node": "22.19.11",
    "@vitest/coverage-v8": "4.0.18",
    "@volar/language-core": "2.4.28",
    "tsx": "4.21.0",
    "vitest": "4.0.18"
  }
}
