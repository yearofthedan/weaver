{
  "name": "@yearofthedan/weaver",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yearofthedan/weaver.git"
  },
  "description": "Headless CLI refactoring engine for AI agents",
  "bin": {
    "weaver": "./dist/adapters/cli/cli.js"
  },
  "type": "module",
  "files": [
    "dist",
    ".claude/skills/search-and-replace",
    ".claude/skills/move-and-rename",
    ".claude/skills/code-inspection"
  ],
  "main": "./dist/adapters/cli/cli.js",
  "exports": {
    ".": "./dist/adapters/cli/cli.js"
  },
  "engines": {
    "node": "v25.8.2"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/adapters/cli/cli.js",
    "dev": "tsx src/adapters/cli/cli.ts",
    "test": "vitest run",
    "test:eval": "vitest run --config eval/vitest.config.ts",
    "test:all": "pnpm test && pnpm test:eval",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "smoke-test": "bash scripts/smoke-test.sh",
    "agent:check": "tsx scripts/agent-check.ts",
    "agent:doctor": "tsx scripts/agent-doctor.ts",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist .stryker-tmp",
    "test:mutate": "rm -rf .stryker-tmp && stryker run",
    "test:mutate:file": "rm -rf .stryker-tmp && stryker run --mutate",
    "eval": "tsx eval/run-eval.ts",
    "check": "biome check . && pnpm build && pnpm test:all",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@volar/typescript": "2.4.28",
    "@vue/language-core": "3.2.6",
    "chokidar": "5.0.0",
    "commander": "14.0.3",
    "safe-regex2": "5.1.0",
    "ts-morph": "27.0.2",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@volar/language-core": "2.4.28"
    },
    "ignoredBuiltDependencies": [
      "@playwright/browser-chromium",
      "@swc/core",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@stryker-mutator/core": "9.6.0",
    "@stryker-mutator/vitest-runner": "9.6.0",
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "4.1.2",
    "@volar/language-core": "2.4.28",
    "husky": "9.1.7",
    "promptfoo": "0.121.3",
    "tsx": "4.21.0",
    "vitest": "4.1.2"
  }
}
