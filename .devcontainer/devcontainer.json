{
  "name": "weaver Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolderBasename}-workspace,target=/workspaces/${localWorkspaceFolderBasename},type=volume",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-extra/features/pnpm:2": {
      "version": "10.30.3"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["Vue.volar", "biomejs.biome", "anthropic.claude-code"],
      "settings": {
        "dev.containers.copyGitConfig": false,
        "dev.containers.gitCredentialHelperConfigLocation": "none",
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit"
        },
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/dist/**": true,
          "**/coverage/**": true,
          "**/.pnpm-store/**": true
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=${localWorkspaceFolderBasename}-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=${localWorkspaceFolderBasename}-extensions,target=/home/node/.vscode-server/extensions,type=volume",
    "source=${localWorkspaceFolderBasename}-global-storage,target=/home/node/.vscode-server/data/User/globalStorage,type=volume"
  ],
  "onCreateCommand": "/usr/local/bin/onCreate.sh https://github.com/yearofthedan/weaver.git",
  "postCreateCommand": "pnpm install",
  "postStartCommand": "curl -fsSL https://claude.ai/install.sh | bash",
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "safe.directory",
    "GIT_CONFIG_VALUE_0": "${containerWorkspaceFolder}"
  }
}
